# =======================================
# TutorSense AI — Environment Variables
# =======================================
# Copy this file to .env.local and fill in your values

# OpenAI API Key (required for AI interview + evaluation)
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Application URL (set when deploying to Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: ElevenLabs for premium voice synthesis
# ELEVENLABS_API_KEY=your_elevenlabs_key_here
# ELEVENLABS_VOICE_ID=your_voice_id_here

# Optional: Supabase for persistent database
# NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
# SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: Clerk authentication for recruiter dashboard
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=your_clerk_publishable_key
# CLERK_SECRET_KEY=your_clerk_secret_key
